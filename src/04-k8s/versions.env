#!/usr/bin/env bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMMON_VERSIONS_FILE="${SCRIPT_DIR}/common/component-versions.env"

if [[ ! -f "${COMMON_VERSIONS_FILE}" ]]; then
  echo "Missing common versions file: ${COMMON_VERSIONS_FILE}" >&2
  return 1 2>/dev/null || exit 1
fi

# shellcheck disable=SC1090
source "${COMMON_VERSIONS_FILE}"

if [[ -z "${ARCH:-}" || "${ARCH:-}" == "unknown" ]]; then
  ARCH="amd64"
fi

if [[ -z "${PLATFORM:-}" || "${PLATFORM:-}" == "unknown" ]]; then
  PLATFORM="linux/${ARCH}"
fi

if [[ -z "${PACKAGE_VARIANT:-}" || "${PACKAGE_VARIANT:-}" == "unknown" ]]; then
  PACKAGE_VARIANT="source"
fi

if [[ -z "${INCLUDE_IMAGES:-}" || "${INCLUDE_IMAGES:-}" == "unknown" ]]; then
  INCLUDE_IMAGES="n/a"
fi

INSTALLER_NAME="${INSTALLER_NAME:-k8s-sealos-linux-${ARCH}-${PACKAGE_VARIANT}.run}"
